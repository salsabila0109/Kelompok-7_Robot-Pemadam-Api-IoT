<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#142E4C"
    android:padding="16dp">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignParentStart="true"
        android:layout_alignTop="@id/tvTitle"
        android:layout_marginStart="4dp"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/icon_backwhite" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:text="@string/kontrol_robot"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold" />

    <Switch
        android:id="@+id/switchStop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_alignParentStart="true"
        android:layout_marginStart="145dp"
        android:layout_marginTop="12dp"

        android:scaleX="1.2"
        android:scaleY="1.2"

        android:switchPadding="4dp"

        android:text="MANUAL"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"

        android:thumbTint="#FFFFFF"
        android:trackTint="#B0BEC5" />

    <LinearLayout
        android:id="@+id/dataSensor"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_below="@id/tvTitle"
        android:layout_marginStart="45dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_datasensor"
        android:elevation="4dp"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/data_sensor"
            android:textColor="#06387A"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvApi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/api_tidak_terdeteksi"
            android:textColor="#06387A" />

        <TextView
            android:id="@+id/tvJarak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/jarak_kontrol2"
            android:textColor="#06387A" />

        <TextView
            android:id="@+id/tvBaterai"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Baterai: -"
            android:textColor="#06387A" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutCamera"
        android:layout_width="300dp"
        android:layout_height="200dp"

        android:layout_centerInParent="true"

        android:background="#0F1F33"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:layout_marginBottom="8dp"

            android:gravity="center"

            android:text="@string/monitoring"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold" />

        <WebView
            android:id="@+id/webViewCamera"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </LinearLayout>

    <!-- CONTROL VERTICAL -->
    <LinearLayout
        android:id="@+id/controlVertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="60dp"
        android:orientation="vertical">

        <!-- MAJU -->
        <Button
            android:id="@+id/btnUp"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:backgroundTint="#3AA6B9"
            android:text="@string/maju"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <!-- MUNDUR -->
        <Button
            android:id="@+id/btnDown"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="#3AA6B9"
            android:text="@string/mundur"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

    </LinearLayout>

    <!-- TOMBOL AIR -->
    <Button
        android:id="@+id/btnSemprot"
        android:layout_width="85dp"
        android:layout_height="55dp"
        android:layout_toStartOf="@id/controlVertical"
        android:layout_centerVertical="true"
        android:layout_marginEnd="35dp"
        android:backgroundTint="#FFFD08"
        android:text="@string/AIR"
        android:textColor="#331E00"
        android:textSize="16sp"
        android:textStyle="bold"/>

    <LinearLayout
        android:id="@+id/controlHorizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignStart="@id/dataSensor"
        android:layout_below="@id/dataSensor"
        android:layout_marginTop="40dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnLeft"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:backgroundTint="#3AA6B9"
            android:text="@string/kiri"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

        <Button
            android:id="@+id/btnRight"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginStart="20dp"
            android:backgroundTint="#3AA6B9"
            android:text="@string/kanan"
            android:textColor="#FFFFFF"
            android:textSize="18sp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnSource"
        android:layout_width="120dp"
        android:layout_height="45dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="10dp"

        android:backgroundTint="#FF1E1E"

        android:text="@string/source"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/layoutSourcePopup"
        android:layout_width="430dp"
        android:layout_height="wrap_content"

        android:layout_centerInParent="true"

        android:background="#EAEAEA"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="14dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:background="#D1D1D1"
            android:orientation="horizontal"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:text="&lt;/&gt;"
                android:textColor="#666666"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etSource"
                android:layout_width="0dp"
                android:layout_height="wrap_content"

                android:layout_weight="1"

                android:background="@android:color/transparent"
                android:hint="@string/source"
                android:paddingStart="8dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:textColor="#000000"
                android:textColorHint="#777777" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:layout_marginTop="12dp"

            android:gravity="end">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:backgroundTint="#FF3B3B"

                android:text="@string/Batal"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"

                android:layout_marginStart="10dp"

                android:backgroundTint="#8E8E8E"

                android:text="@string/Ya"
                android:textColor="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>