<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#142E4C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- LOGO -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_marginTop="90dp"
            android:src="@drawable/logo_firebot" />

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/login_selamatdatang"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"/>

        <!-- SUBTITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/masukkan_key"
            android:textColor="#BDBDBD"
            android:textSize="15sp"
            android:layout_marginTop="6dp"/>

        <!-- INPUT + ICON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="50dp"
            android:orientation="horizontal"
            android:background="#2A3F5F"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <!-- ICON KEY (KIRI) -->
            <ImageView
                android:layout_width="27dp"
                android:layout_height="27dp"
                android:src="@drawable/icon_key" />

            <!-- EDITTEXT -->
            <EditText
                android:id="@+id/etKey"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:hint="@string/key"
                android:background="@android:color/transparent"
                android:textColor="#FFFFFF"
                android:textColorHint="#BDBDBD"
                android:inputType="textPassword"/>

            <!-- ICON MATA (KANAN) -->
            <ImageView
                android:id="@+id/btnEye"
                android:layout_width="27dp"
                android:layout_height="27dp"
                android:src="@drawable/icon_eye_off"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- BUTTON LOGIN -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="25dp"
            android:text="@string/login"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#E50914"/>

    </LinearLayout>

</ScrollView>